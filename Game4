local function SendGift(id, categoryType)
    if not GiftRemote then 
        Rayfield:Notify({Title = "Error", Content = "'Gift' remote not found.", Duration = 3})
        return 
    end
    
    local targetObj = Players:FindFirstChild(TargetPlayerName)
    if not targetObj then return end

    local args = {
        id,
        categoryType,
        targetObj 
    }
    
    GiftRemote:FireServer(unpack(args))
end

