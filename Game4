local Settings = { AutoSpoof = true }

local function ForceExtremeSpoof(id)
    local numId = tonumber(id)
    if not numId then return end
    task.spawn(function()
        pcall(function()
            local get_id = getidentity or (syn and syn.get_thread_identity)
            local set_id = setthreadidentity or (syn and syn.set_thread_identity)
            local old_id = get_id and get_id() or 2
            
            if set_id then set_id(8) end
            MarketplaceService:SignalPromptProductPurchaseFinished(LocalPlayer.UserId, numId, true)
            MarketplaceService:SignalPromptGamePassPurchaseFinished(LocalPlayer, numId, true)
            MarketplaceService:SignalPromptPurchaseFinished(LocalPlayer, numId, true)
            if set_id then set_id(old_id) end
        end)
    end)
end

if hookmetamethod then
    local oldNamecall
    oldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        if not checkcaller() and Settings.AutoSpoof then
            if string.match(method, "^Prompt.*Purchase") and tostring(self) == "MarketplaceService" then
                local id = args[2] or args[1]
                if tonumber(id) then
                    ForceExtremeSpoof(tonumber(id))
                    return 
                end
            end
        end
        return oldNamecall(self, ...)
    end))
end

local function OnServerPrompt(ply, id)
    if Settings.AutoSpoof and ply == LocalPlayer then
        ForceExtremeSpoof(id)
    end
end
MarketplaceService.PromptGamePassPurchaseRequested:Connect(OnServerPrompt)
