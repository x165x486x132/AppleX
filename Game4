local function ExtractItems(folderName)
    local items = {}
    if not ShopFolders then return items end
    local folder = ShopFolders:FindFirstChild(folderName)
    if folder then
        for _, itemFolder in ipairs(folder:GetChildren()) do
            local giftIdVal = itemFolder:FindFirstChild("GiftID")
            if giftIdVal then items[itemFolder.Name] = giftIdVal.Value end
        end
    end
    return items
end

local Categories = {
    Gamepass = ExtractItems("Gamepasses"),
    Booster = ExtractItems("Boosters"),
    Money = ExtractItems("Money")
}

local TargetPlayerName = "All"
local SelectedCategory = "Gamepass"
local SelectedItemName = ""

local function GetPlayerNames()
    local names = {"All"}
    for _, p in ipairs(Players:GetPlayers()) do 
        table.insert(names, p.Name) 
    end
    return names
end

local function GetItemNames(cat)
    local names = {}
    if Categories[cat] then
        for k, _ in pairs(Categories[cat]) do table.insert(names, k) end
    end
    if #names == 0 then table.insert(names, "None") end
    return names
end

local function SendGift(id, categoryType)
    if not GiftRemote then return end
    if TargetPlayerName == "All" then
        for _, p in ipairs(Players:GetPlayers()) do
            GiftRemote:FireServer(id, categoryType, p)
        end
    else
        local targetObj = Players:FindFirstChild(TargetPlayerName)
        if targetObj then
            GiftRemote:FireServer(id, categoryType, targetObj)
        end
    end
end

