local function BuildCategoryUI(tab, title, itemsTable, remoteTypeStr)
    tab:CreateSection("🎁 " .. title)
    
    local names = {}
    for name, _ in pairs(itemsTable) do table.insert(names, name) end
    
    if #names == 0 then return end

    local selectedItemName = names[1]

    tab:CreateDropdown({
        Name = "Select : " .. title,
        Options = names,
        CurrentOption = {selectedItemName},
        MultipleOptions = false,
        Flag = title.."Drop",
        Callback = function(Option)
            selectedItemName = Option[1]
        end,
    })

    tab:CreateButton({
        Name = "🎁 Send Selected",
        Callback = function()
            local id = itemsTable[selectedItemName]
            if id then
                SendGift(id, remoteTypeStr)
                Rayfield:Notify({Title = "Sent", Content = selectedItemName .. " sent.", Duration = 2})
            end
        end,
    })

    tab:CreateButton({
        Name = "💥 SEND ALL",
        Callback = function()
            task.spawn(function()
                for _, id in pairs(itemsTable) do
                    SendGift(id, remoteTypeStr)
                    task.wait(0.4) 
                end
                Rayfield:Notify({Title = "Completed", Content = "Mass gift completed.", Duration = 4})
            end)
        end,
    })
end

