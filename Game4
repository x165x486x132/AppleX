local ShopFolders = ReplicatedStorage:WaitForChild("ShopFolders", 5)
local Remotes = ReplicatedStorage:WaitForChild("Remotes", 5)
local GiftRemote = Remotes and Remotes:WaitForChild("Gift", 5)

local function ExtractItems(folderName)
    local items = {}
    if not ShopFolders then return items end
    local folder = ShopFolders:FindFirstChild(folderName)
    
    if folder then
        for _, itemFolder in ipairs(folder:GetChildren()) do
            local giftIdVal = itemFolder:FindFirstChild("GiftID")
            if giftIdVal then
                items[itemFolder.Name] = giftIdVal.Value
            end
        end
    end
    return items
end

local GamepassList = ExtractItems("Gamepasses")
local BoosterList = ExtractItems("Boosters")
local MoneyList = ExtractItems("Money")

local TargetPlayerName = LocalPlayer.Name

local function GetPlayerNames()
    local names = {}
    for _, p in ipairs(Players:GetPlayers()) do table.insert(names, p.Name) end
    return names
end

