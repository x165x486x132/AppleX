local function SendGift(id, categoryType)
    if not GiftRemote then return end
    
    if TargetPlayerName == "All" then
        for _, p in ipairs(Players:GetPlayers()) do
            GiftRemote:FireServer(id, categoryType, p)
        end
    else
        local targetObj = Players:FindFirstChild(TargetPlayerName)
        if targetObj then
            GiftRemote:FireServer(id, categoryType, targetObj)
        end
    end
end

