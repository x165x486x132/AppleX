local function BuildCategoryUI(tab, title, itemsTable, remoteTypeStr)
    tab:CreateSection("🎁 " .. title)
    
    local names = {}
    for name, _ in pairs(itemsTable) do table.insert(names, name) end
    
    if #names == 0 then
        tab:CreateLabel("❌ No items found in " .. title)
        return
    end

    local selectedItemName = names[1]

    tab:CreateDropdown({
        Name = "Select : " .. title,
        Options = names,
        CurrentOption = {selectedItemName},
        MultipleOptions = false,
        Flag = title.."Drop",
        Callback = function(Option)
            selectedItemName = Option[1]
        end,
    })

    tab:CreateButton({
        Name = "🎁 Send Selected Item",
        Callback = function()
            local id = itemsTable[selectedItemName]
            if id then
                SendGift(id, remoteTypeStr)
                Rayfield:Notify({Title = "Gift Sent", Content = "You sent: " .. selectedItemName .. " to " .. TargetPlayerName, Duration = 2})
            end
        end,
    })

    tab:CreateButton({
        Name = "💥 SEND ALL (Mass Gift)",
        Callback = function()
            Rayfield:Notify({Title = "Processing Mass Gift", Content = "Sending all " .. title .. " (Please wait a few seconds)...", Duration = 3})
            
            -- Runs in background so it doesn't freeze the menu
            task.spawn(function()
                for name, id in pairs(itemsTable) do
                    SendGift(id, remoteTypeStr)
                    task.wait(0.4) -- SLOWED DOWN: Forces the server to process every single item correctly!
                end
                Rayfield:Notify({Title = "Mass Gift Completed", Content = "All " .. title .. " were successfully sent to " .. TargetPlayerName, Duration = 4})
            end)
        end,
    })
end

